{
  "name": "@samfp/pi-workflows",
  "version": "0.3.0",
  "description": "Dynamic workflows for pi — sandboxed JS scripts that drive sub-agent fleets, with TUI inspection and resume",
  "keywords": [
    "pi-package",
    "pi-extension",
    "workflows",
    "subagents",
    "claude-code-parity"
  ],
  "private": false,
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "import": "./dist/testing.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node esbuild.config.js",
    "build:types": "tsc -p tsconfig.build.json --emitDeclarationOnly",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test tests/unit/*.test.ts tests/security/*.test.ts && node --import tsx --test --test-force-exit tests/integration/skeleton.smoke.ts && node --import tsx --test tests/integration/*.test.ts",
    "test:unit": "node --import tsx --test tests/unit/*.test.ts",
    "test:integration": "node --import tsx --test tests/integration/*.smoke.ts tests/integration/*.test.ts",
    "test:security": "node --import tsx --test tests/security/*.test.ts",
    "smoke:otel": "node -e \"console.log('See examples/otel-smoke/README.md for the OTel smoke-test recipe.')\"",
    "prepublishOnly": "npm run build && npm test",
    "coverage": "c8 --include='src/runtime/**' --include='src/util/**' --reporter=text --reporter=lcov node --import tsx --test tests/unit/*.test.ts tests/integration/*.smoke.ts tests/integration/*.test.ts tests/security/*.test.ts",
    "coverage:check": "c8 check-coverage --lines 85 --branches 70 --include='src/runtime/**' --include='src/util/**'"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "typebox": "^1.0.0"
  },
  "peerDependenciesMeta": {
    "typebox": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "c8": "^11.0.0",
    "esbuild": "^0.28.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0"
  },
  "pi": {
    "extensions": [
      "./dist/index.js"
    ],
    "skills": [
      "./skills/pi-workflows/SKILL.md"
    ]
  },
  "files": [
    "dist/",
    "docs/",
    "examples/",
    "skills/",
    "README.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "LICENSE"
  ],
  "dependencies": {
    "chokidar": "^5.0.0",
    "isexe": "^4.0.0"
  },
  "optionalDependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.218.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.218.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-metrics": "^2.7.1",
    "@opentelemetry/sdk-trace-base": "^2.7.1",
    "@opentelemetry/sdk-trace-node": "^2.7.1",
    "@opentelemetry/semantic-conventions": "^1.41.1"
  }
}
